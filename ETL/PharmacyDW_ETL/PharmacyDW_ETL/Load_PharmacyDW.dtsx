    <DTS:Executable
      DTS:refId="Package\SQL_Insert_Inferred_DimProduct"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B5F809A6-C6C8-4C4D-A661-725F60BD83A4}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Insert_Inferred_DimProduct"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{8BB18D7D-5388-4ACB-91ED-A1A2F91207AC}"
          SQLTask:SqlStatementSource="INSERT INTO PharmacyDW.dw.DimProduct&#xA;(&#xA;    KD_OBAT,&#xA;    ProductName,&#xA;    UnitType,&#xA;    ManufacturerCode,&#xA;    BaseSellingPrice,&#xA;    Category,&#xA;    Subcategory,&#xA;    BrandGroup,&#xA;    Manufacturer,&#xA;    EffectiveFromDate,&#xA;    EffectiveToDate,&#xA;    IsCurrent,&#xA;    SourceSystem&#xA;)&#xA;SELECT v.KD_OBAT,&#xA;       N'Missing master record - ' + v.KD_OBAT,&#xA;       N'Unknown',&#xA;       N'Unknown',&#xA;       0,&#xA;       N'Unknown',&#xA;       N'Unknown',&#xA;       N'Unknown',&#xA;       N'Unknown',&#xA;       GETDATE(),&#xA;       '9999-12-31',&#xA;       1,&#xA;       N'INFERRED_FROM_FACT'&#xA;FROM (VALUES&#xA;    (N'AI-0954'),&#xA;    (N'AI-1539'),&#xA;    (N'R-0380'),&#xA;    (N'R-1848'),&#xA;    (N'R-2827'),&#xA;    (N'R-4681')&#xA;) v(KD_OBAT)&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1&#xA;    FROM PharmacyDW.dw.DimProduct d&#xA;    WHERE LTRIM(RTRIM(d.KD_OBAT)) = LTRIM(RTRIM(v.KD_OBAT))&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\SQL_Load_DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{E41762D1-1310-4596-BCFE-F451B22A2898}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Load_DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{8BB18D7D-5388-4ACB-91ED-A1A2F91207AC}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM dw.DimDate WHERE DateKey = 20250101)&#xA;BEGIN&#xA;    DECLARE @StartDate DATE = '2015-01-01';&#xA;    DECLARE @EndDate DATE = '2015-12-31';&#xA;&#xA;    WHILE @StartDate &lt;= @EndDate&#xA;    BEGIN&#xA;        INSERT INTO dw.DimDate&#xA;        (&#xA;            DateKey,&#xA;            FullDate,&#xA;            DayNumber,&#xA;            DayName,&#xA;            MonthNumber,&#xA;            MonthName,&#xA;            QuarterNumber,&#xA;            YearNumber,&#xA;            WeekNumber,&#xA;            IsWeekend&#xA;        )&#xA;        VALUES&#xA;        (&#xA;            CONVERT(INT, CONVERT(VARCHAR(8), @StartDate, 112)),&#xA;            @StartDate,&#xA;            DAY(@StartDate),&#xA;            DATENAME(WEEKDAY, @StartDate),&#xA;            MONTH(@StartDate),&#xA;            DATENAME(MONTH, @StartDate),&#xA;            DATEPART(QUARTER, @StartDate),&#xA;            YEAR(@StartDate),&#xA;            DATEPART(WEEK, @StartDate),&#xA;            CASE&#xA;                WHEN DATENAME(WEEKDAY, @StartDate) IN ('Saturday', 'Sunday') THEN 1&#xA;                ELSE 0&#xA;            END&#xA;        );&#xA;&#xA;        SET @StartDate = DATEADD(DAY, 1, @StartDate);&#xA;    END&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
